{
  "name": "gooby",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "GOOBY — a polished Pou/Talking-Tom-style virtual-pet game starring a fat rabbit (three.js web app, Capacitor iOS wrap)",
  "scripts": {
    "dev": "vite --port 5174 --strictPort --host",
    "build": "vite build",
    "preview": "vite preview --port 5174",
    "test": "node --test \"test/*.test.js\"",
    "lint": "eslint .",
    "px-audit": "node scripts/px-audit.mjs",
    "fetch-assets": "node scripts/fetch-kenney.mjs",
    "fetch-itch": "node scripts/fetch-itch.mjs",
    "music-manifest": "node scripts/gen-music-manifest.mjs",
    "beats": "node scripts/gen-beats.mjs",
    "icons": "node scripts/gen-icons.mjs",
    "shot": "node scripts/screenshot.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.8",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/haptics": "^7.0.5",
    "@capacitor/ios": "^7.6.8",
    "@capacitor/local-notifications": "^7.0.7",
    "@capacitor/preferences": "^7.0.4",
    "@capacitor/share": "^7.0.4",
    "@mkkellogg/gaussian-splats-3d": "0.4.7",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.8",
    "@eslint/js": "^9",
