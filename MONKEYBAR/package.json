{
  "name": "monkeybar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "MONKEYBAR — online multiplayer monkey bluff party game (three.js client, authoritative ws server)",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "npm run build -w client",
    "start": "NODE_ENV=production node server/src/index.js",
    "test": "node --test \"shared/test/*.test.js\" \"server/test/*.test.js\"",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "three": "^0.170.0",
    "ws": "^8"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "eslint": "^9",
    "vite": "^6"
  }
}
